{
  "name": "nova-cli",
  "version": "1.0.0",
  "description": "🚀 NOVA — Next-gen Orchestrated Virtual Assistant. Enterprise AI coding assistant powered by Ollama.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nova": "./bin/nova.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "nova": "node bin/nova.js",
    "clean": "rimraf dist",
    "lint": "eslint src/",
    "prepare": "npm run build"
  },
  "keywords": [
    "ai",
    "cli",
    "ollama",
    "coding-assistant",
    "terminal",
    "llm"
  ],
  "author": "NOVA Team",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "fast-glob": "^3.3.2",
    "marked": "^14.1.0",
    "marked-terminal": "^7.2.1",
    "ora": "^8.1.0",
    "better-sqlite3": "^11.6.0",
    "chokidar": "^4.0.1",
    "figures": "^6.1.0",
    "strip-ansi": "^7.1.0",
    "wrap-ansi": "^9.0.0",
    "string-width": "^7.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
